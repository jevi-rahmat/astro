---
import { slugify, formatDate } from "../js/utils";

const { frontmatter } = Astro.props;
const { title, description, date, category, author, image } = frontmatter;
---

<header>
    <div class="container">
        <small>
            <a href={`/category/${slugify(category)}/`} class="badge"
                >{category}</a
            >
        </small>
        <h1>{title}</h1>
        <p>By <a href={`/author/${slugify(author)}/`}>{author}</a></p>
        <p>{formatDate(date)}</p>
    </div>
    <div class="blog-img">
        <img src={image.src} alt={image.alt} width="600" />
    </div>
</header>

<style>
    .blog-img {
        display: flex;
        justify-content: center;
    }

    .blog-img img {
        border-radius: 10px;
        box-shadow: 10px 10px 10px rgb(170, 170, 170);
    }
</style>